---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short', day: 'numeric' });

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog"
  description="Notes on building MCP servers, AI tooling, full-stack work, and developer experience."
>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
    <p class="mt-2 text-muted">
      Long-form notes. For quick snippets and gotchas, see <a class="link" href="/notes/">notes</a>.
    </p>
    {allTags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-1.5">
        {allTags.map((tag) => <li class="badge">#{tag}</li>)}
      </ul>
    )}
  </header>

  {posts.length === 0 ? (
    <p class="text-muted">First post landing soon.</p>
  ) : (
    <ul class="divide-y divide-border">
      {posts.map((post) => (
        <li class="py-5">
          <a href={`/blog/${post.slug}/`} class="group block">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h2 class="font-semibold group-hover:text-accent">{post.data.title}</h2>
              <time class="text-xs text-muted" datetime={post.data.pubDate.toISOString()}>
                {fmt.format(post.data.pubDate)}
              </time>
            </div>
            <p class="mt-1 text-sm text-muted">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
