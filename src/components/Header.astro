---
import { SITE, NAV } from '@/consts';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="border-b border-border bg-bg/80 backdrop-blur sticky top-0 z-40">
  <div class="container-wide flex h-14 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="inline-block h-2 w-2 rounded-full bg-accent"></span>
      {SITE.name}
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {
        NAV.slice(1).map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-1.5 transition-colors',
              isActive(item.href) ? 'text-fg' : 'text-muted hover:text-fg',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <span class="mx-2 h-5 w-px bg-border"></span>
      <ThemeToggle />
    </nav>
  </div>
</header>
